@model IEnumerable<GestorDeMembresia.UI.Services.MembresiaDto>

@{
    ViewData["Title"] = "Membresías Vencidas";
}

<div class="container mt-5">
    <!-- 🔎 Campo de búsqueda -->
    <form asp-action="Vencidas" method="get" class="mb-3">
        <div class="input-group">
            <input type="text" name="identificacion" class="form-control" placeholder="Buscar por identificación..." />
            <button type="submit" class="btn btn-primary">Buscar</button>
        </div>
    </form>

    <!-- ✅ Mensajes de éxito o error -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success text-center fw-bold">@TempData["Mensaje"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger text-center fw-bold">@TempData["Error"]</div>
    }

    <div class="card shadow-lg">
        <div class="card-header bg-danger text-white text-center">
            <h4>Membresías Vencidas</h4>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Identificación</th>
                            <th>Nombre</th>
                            <th>Apellidos</th>
                            <th>Teléfono</th>
                            <th>Tipo de Plan</th>
                            <th>Fecha Inicio</th>
                            <th>Fecha Vencimiento</th>
                            <th>Estado</th>
                            <th>Monto Total</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td>@m.Identificacion</td>
                                <td>@m.Nombre</td>
                                <td>@m.Apellidos</td>
                                <td>@m.Telefono</td>
                                <td>@m.TipoDePlan</td>
                                <td>@m.FechaDeInicio.ToShortDateString()</td>
                                <td>@m.FechaDeVencimiento.ToShortDateString()</td>
                                <td>
                                    <span class="badge bg-danger">Vencida</span>
                                </td>
                                <td>₡@m.MontoTotal</td>
                                <td>
                                    <a asp-action="Detalle" asp-route-id="@m.Identificacion" class="btn btn-info btn-sm">Ver detalle</a>
                                    <a asp-action="Editar" asp-route-id="@m.Identificacion" class="btn btn-warning btn-sm">Editar</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning text-center fw-bold">
                    No hay membresías vencidas registradas.
                </div>
            }
        </div>
    </div>
</div>


