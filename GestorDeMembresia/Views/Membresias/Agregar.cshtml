@model GestorDeMembresia.UI.Services.MembresiaDto

<div class="container mt-5">
    <div class="card shadow-lg">
        <div class="card-header bg-primary text-white text-center">
            <h4>Registrar Membresía</h4>
        </div>
        <div class="card-body">
            <form asp-action="Agregar" method="post">
                <div class="mb-3">
                    <label asp-for="Identificacion" class="form-label fw-bold"></label>
                    <input asp-for="Identificacion" class="form-control" required />
                    <span asp-validation-for="Identificacion" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Nombre" class="form-label fw-bold"></label>
                    <input asp-for="Nombre" class="form-control" required />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Apellidos" class="form-label fw-bold"></label>
                    <input asp-for="Apellidos" class="form-control" required />
                    <span asp-validation-for="Apellidos" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Telefono" class="form-label fw-bold"></label>
                    <input asp-for="Telefono" class="form-control" required />
                    <span asp-validation-for="Telefono" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="PrecioBaseMensual" class="form-label fw-bold"></label>
                    <input asp-for="PrecioBaseMensual" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="PrecioBaseMensual" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="TipoDePlan" class="form-label fw-bold"></label>
                    <select asp-for="TipoDePlan" class="form-select" required>
                        <option value="1">Mensual</option>
                        <option value="2">Trimestral</option>
                        <option value="3">Anual</option>
                    </select>
                    <span asp-validation-for="TipoDePlan" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FechaDeInicio" class="form-label fw-bold"></label>
                    <input asp-for="FechaDeInicio" type="date" class="form-control" required />
                    <span asp-validation-for="FechaDeInicio" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="FechaDeVencimiento" class="form-label fw-bold"></label>
                    <input asp-for="FechaDeVencimiento" type="date" class="form-control" required />
                    <span asp-validation-for="FechaDeVencimiento" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Estado" class="form-label fw-bold"></label>
                    <select asp-for="Estado" class="form-select">
                        <option value="1">Activa</option>
                        <option value="2">Vencida</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="MontoTotal" class="form-label fw-bold"></label>
                    <input asp-for="MontoTotal" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="MontoTotal" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Registrar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>


