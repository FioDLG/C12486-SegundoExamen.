@model IEnumerable<GestorDeMembresia.UI.Services.MembresiaDto>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Identificación</th>
            <th>Nombre</th>
            <th>Apellidos</th>
            <th>Teléfono</th>
            <th>Precio Base</th>
            <th>Tipo de Plan</th>
            <th>Fecha Inicio</th>
            <th>Fecha Vencimiento</th>
            <th>Estado</th>
            <th>Monto Total</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var membresia in Model)
        {
            <tr>
                <td>@membresia.Identificacion</td>
                <td>@membresia.Nombre</td>
                <td>@membresia.Apellidos</td>
                <td>@membresia.Telefono</td>
                <td>@membresia.PrecioBaseMensual.ToString("F2")</td>
                <td>@membresia.NombrePlan</td> 
                <td>@membresia.FechaDeInicio.ToShortDateString()</td>
                <td>@membresia.FechaDeVencimiento.ToShortDateString()</td>
                <td>@(membresia.Estado == 1 ? "Activa" : "Vencida")</td>
                <td>@membresia.MontoTotal.ToString("F2")</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@membresia.Identificacion" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Editar" asp-route-id="@membresia.Identificacion" class="btn btn-warning btn-sm">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
